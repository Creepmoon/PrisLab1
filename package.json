{
  "name": "edusphere-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "services/*",
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "npm run start --workspace services/api-gateway",
    "start:all": "node scripts/start-all.mjs",
    "lint": "npm run lint --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  },
  "engines": {
    "node": ">=20"
  }
}
